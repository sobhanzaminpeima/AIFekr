generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  phone          String?   @unique
  passwordHash   String?
  name           String?
  avatar         String?
  role           String    @default("USER")
  plan           String    @default("FREE")
  credits        Int       @default(100)
  planExpiry     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  isBlocked      Boolean   @default(false)
  industryPackId String?
  /// Google OAuth subject id — set when the user signs in with Google
  googleId       String?   @unique
  /// How this account authenticates: "password" | "google"
  authProvider   String    @default("password")

  conversations     Conversation[]
  projects          Project[]
  images            GeneratedImage[]
  videos            GeneratedVideo[]
  musics            GeneratedMusic[]
  payments          Payment[]
  usageLogs         UsageLog[]
  otpCodes          OtpCode[]
  crmContacts       CrmContact[]
  businessAnalyses  BusinessAnalysis[]
  socialPosts       SocialPost[]
  generatedWebsites GeneratedWebsite[]
  industryPack      IndustryPack?      @relation(fields: [industryPackId], references: [id])
  company           Company?
  ownedTeam         Team?              @relation("TeamOwner")
  teamMembership    TeamMember?
  seoConnection     SeoConnection?
  instagramConn     InstagramConnection?
  scheduledPosts    ScheduledPost[]

  @@index([industryPackId])
}

/// A TEAM-plan subscription shared by up to maxSeats users. Credits are
/// pooled here instead of on each User.credits once someone joins as a
/// member — see src/lib/utils/teamCredits.ts.
model Team {
  id         String    @id @default(cuid())
  name       String
  ownerId    String    @unique
  credits    Int       @default(0)
  planExpiry DateTime?
  maxSeats   Int       @default(5)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TeamMember[]
  invites TeamInvite[]
}

/// One row per seat filled on a Team (including the owner, so credit
/// deduction can treat every member — owner or not — the same way).
model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String   @unique
  role     String   @default("MEMBER") // OWNER | MEMBER
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

/// A pending seat invitation sent by email, redeemed via a one-time token.
model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  token     String   @unique
  status    String   @default("PENDING") // PENDING | ACCEPTED | REVOKED | EXPIRED
  invitedBy String
  createdAt DateTime @default(now())
  expiresAt DateTime

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
}

/// Folders for organizing conversations. Was applied directly to the
/// production DB via SSH before this model existed in git — keep this in
/// sync with prisma/migrations, don't let it drift again.
model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String   @default("#ea580c")
  icon        String   @default("folder")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([phone])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  tool      String?
  model     String   @default("claude-haiku-4-5-20251001")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id])
  messages Message[]

  @@index([userId])
  @@index([projectId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokens         Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model GeneratedImage {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  style     String   @default("realistic")
  url       String
  isPublic  Boolean  @default(false)
  credits   Int      @default(5)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GeneratedVideo {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  duration  Int      @default(5)
  url       String
  isPublic  Boolean  @default(false)
  credits   Int      @default(20)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GeneratedMusic {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  genre     String   @default("pop")
  duration  Int      @default(30)
  url       String
  isPublic  Boolean  @default(false)
  credits   Int      @default(10)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  plan      String
  status    String   @default("PENDING")
  gateway   String   @default("zarinpal")
  refId     String?
  authority String?  @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  model     String?
  tokens    Int?
  credits   Int      @default(1)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Prompt {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmContact {
  id          String    @id @default(cuid())
  userId      String?
  name        String
  phone       String?
  email       String?
  company     String?
  status      String    @default("lead")
  source      String    @default("organic")
  plan        String?
  totalSpent  Int       @default(0)
  notes       String?
  tags        String?
  lastContact DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

/// This is the single source of truth for general-plan pricing — the
/// /plans page and /api/payment/create both read from here (matched via
/// planCode) instead of a hardcoded array, so an admin edit here actually
/// changes what users see and pay. planCode must match one of the values
/// stored on User.plan (currently BASIC | PRO | TEAM — FREE has no row
/// here since it isn't purchasable).
model Package {
  id          String   @id @default(cuid())
  planCode    String   @unique
  name        String
  nameEn      String
  price       Int
  duration    Int      @default(30)
  credits     Int
  features    String
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  color       String   @default("#ea580c")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LlmModel {
  id          String   @id @default(cuid())
  name        String
  provider    String   @default("anthropic")
  modelId     String   @unique
  description String?
  maxTokens   Int      @default(4096)
  creditCost  Int      @default(1)
  isActive    Boolean  @default(true)
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessAnalysis {
  id           String   @id @default(cuid())
  userId       String
  businessName String
  industry     String
  result       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SocialPost {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  topic     String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GeneratedWebsite {
  id           String   @id @default(cuid())
  userId       String
  businessName String
  htmlCode     String
  brief        String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Lets the SEO agent actually apply changes instead of only suggesting
/// them. "aifekr" needs no credentials (writes GeneratedWebsite.htmlCode
/// directly); "wordpress" needs a site URL + an Application Password the
/// user generates in wp-admin (never their real account password);
/// "other" has no auto-apply path — the agent only outputs recommendations.
/// One Instagram Business account per user, linked via Facebook OAuth
/// (Instagram Graph API requires a Business/Creator account connected to a
/// Facebook Page — there's no way around that, it's a Meta platform rule).
model InstagramConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  igUserId     String
  igUsername   String?
  pageId       String
  accessToken  String
  tokenExpiry  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// A generated Instagram post queued to go out. mode="auto" actually calls
/// the Instagram Graph API at scheduledFor (gated to PRO/TEAM plans —
/// see src/lib/utils/planGates.ts); mode="manual" just sits here so the
/// user can copy the caption/hashtags and post it themselves.
model ScheduledPost {
  id            String    @id @default(cuid())
  userId        String
  caption       String
  hashtags      String
  imageUrl      String?
  scheduledFor  DateTime
  mode          String // "auto" | "manual"
  status        String    @default("PENDING") // PENDING | PUBLISHED | FAILED
  igMediaId     String?
  errorMessage  String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, scheduledFor])
}

model SeoConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  platform      String // "wordpress" | "aifekr" | "other"
  siteUrl       String?
  wpUsername    String?
  wpAppPassword String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IndustryPack {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  emoji            String
  tagline          String
  valueProposition String
  targetCustomers  String
  painPoints       String
  agents           String
  outcomes         String
  kpis             String
  tier             String   @default("professional")
  price            Int      @default(299)
  color            String
  gradientFrom     String
  gradientTo       String
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  users            User[]
  companies        Company[]
}

model BusinessCategory {
  id        String    @id @default(cuid())
  name      String
  nameEn    String
  icon      String    @default("🏢")
  color     String    @default("#ea580c")
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  companies Company[]
}

model Company {
  id             String    @id @default(cuid())
  userId         String    @unique
  name           String
  industry       String
  website        String?
  phone          String?
  email          String?
  address        String?
  size           String?
  revenue        String?
  industryPackId String?
  categoryId     String?
  isActive       Boolean   @default(true)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  industryPack IndustryPack?     @relation(fields: [industryPackId], references: [id])
  category     BusinessCategory? @relation(fields: [categoryId], references: [id])

  @@index([industryPackId])
  @@index([categoryId])
}

/// Logged every time the AI router falls back to a different provider.
/// Used by the admin panel to surface reliability issues.
model ProviderFallbackLog {
  id           String   @id @default(cuid())
  /// Provider that failed (e.g. "claude", "openai")
  fromProvider String
  /// Provider that took over; null if all failed
  toProvider   String?
  /// Error or timeout message (truncated to 500 chars)
  reason       String
  /// Detected prompt category (code, math, general, …)
  category     String   @default("general")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([fromProvider])
}
