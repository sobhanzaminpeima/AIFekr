# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_platform"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
JWT_SECRET="your-jwt-secret-here"

# Google OAuth (Sign in with Google) — console.cloud.google.com
# Authorized redirect URI must be: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ── AI Provider Router ─────────────────────────────────────────────────────
# Comma-separated priority order. The router tries providers left-to-right,
# falling back automatically on error or timeout (>10 s to first token).
# See src/lib/ai/router.ts and src/lib/ai/providers/ for implementation.
AI_PROVIDER_PRIORITY="claude,openai,gemini,deepseek"

# Set to a provider id to force that provider to be skipped (for testing)
# FORCE_PROVIDER_FAILURE="claude"

# Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-haiku-4-5-20251001"

# OpenAI GPT
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Google Gemini
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash"

# DeepSeek
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-chat"

# Stability AI (image generation)
STABILITY_API_KEY="sk-..."

# ElevenLabs (music generation, primary — falls back to Replicate if unset)
ELEVENLABS_API_KEY="sk_..."

# Replicate (music generation fallback + video generation)
REPLICATE_API_TOKEN="r8_..."

# SMS (کاوه‌نگار)
SMS_API_KEY="your-sms-api-key"
SMS_SENDER="10008566"

# Payment - ZarinPal
ZARINPAL_MERCHANT="your-merchant-id"
ZARINPAL_SANDBOX="true"

# Payment - IDPay
IDPAY_API_KEY="your-idpay-key"

# Redis
REDIS_URL="redis://localhost:6379"

# Storage (Cloudflare R2 یا AWS S3)
STORAGE_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY="your-access-key"
STORAGE_SECRET_KEY="your-secret-key"
STORAGE_BUCKET="ai-platform"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="هوشمند AI"

# Instagram automation — Meta Developer App (developers.facebook.com) with
# the Instagram Graph API product added. instagram_content_publish needs
# App Review (Advanced Access) before it works for accounts other than
# testers added on the app itself.
META_APP_ID=""
META_APP_SECRET=""
# Shared secret for the crontab entry that hits /api/cron/instagram-publish
CRON_SECRET=""
